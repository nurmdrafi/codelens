{
  "name": "codelens",
  "version": "0.0.9",
  "description": "Multi-domain code review and analysis for Claude Code: security, architecture, code quality, and accessibility — on your full repo, a module, or a PR diff. Beta.",
  "author": {
    "name": "nurmdrafi",
    "url": "https://github.com/nurmdrafi"
  },
  "homepage": "https://github.com/nurmdrafi/codelens",
  "repository": "https://github.com/nurmdrafi/codelens",
  "license": "MIT",
  "keywords": [
    "code-review",
    "security",
    "accessibility",
    "architecture",
    "code-quality",
    "owasp",
    "wcag",
    "audit"
  ],
  "skills": "./skills/",
  "mcpServers": {
    "context-mode": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "context-mode"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  },
  "permissions": {
    "allow": [
      "mcp__plugin_context-mode_context-mode__*",
      "mcp__plugin_context7_context7__*",
      "WebSearch",
      "Read",
      "Write",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(command:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(biome:*)",
      "Bash(fallow:*)",
      "Bash(tsc:*)",
      "Bash(sg:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(bash:*)",
      "Bash(rm -f:*)"
    ]
  }
}

